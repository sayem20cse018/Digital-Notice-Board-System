# ─────────────────────────────────────────────
# Copy this file to .env.local for local dev
# Set these as Environment Variables in Vercel
# ─────────────────────────────────────────────

# MongoDB Atlas connection string (required in production)
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI="mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/notis-app?retryWrites=true&w=majority"

# Also supported as DATABASE_URL (either one works)
# DATABASE_URL="mongodb+srv://..."

# NextAuth — NEXTAUTH_URL must be your Vercel deployment URL in production
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Admin credentials (stored server-side only — never use NEXT_PUBLIC_ prefix)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-strong-password"

# Public URL used for QR code generation
# In production: set to your Vercel URL e.g. https://your-app.vercel.app
# Locally: set to your PC's LAN IP so phones can scan QR codes
PUBLIC_APP_URL="http://localhost:3000"

# Set to "1" to bypass MongoDB and use local JSON files (dev/demo only)
# Never set this in production
# SKIP_DB=1
