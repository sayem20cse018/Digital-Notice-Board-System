# ─────────────────────────────────────────────────────
# Copy this file to .env.local for local dev
# Set ALL of these as Environment Variables in Vercel
# ─────────────────────────────────────────────────────

# MongoDB Atlas connection string (required)
DATABASE_URL="mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/notis-app?retryWrites=true&w=majority&appName=Cluster0"

# NextAuth — set NEXTAUTH_URL to your Vercel deployment URL in production
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Admin credentials (server-side only — never use NEXT_PUBLIC_ prefix)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-strong-password"

# Public URL for QR codes — phones must be able to reach this URL
# Local dev: your PC's LAN IP e.g. http://192.168.1.5:3000
# Vercel: your deployment URL e.g. https://your-app.vercel.app
PUBLIC_APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────
# Cloudinary — REQUIRED for file uploads on Vercel
# Vercel filesystem is read-only, so files must go to Cloudinary
# Free tier: https://cloudinary.com/users/register/free
# ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_UPLOAD_PRESET="your-unsigned-upload-preset"
# Create an UNSIGNED upload preset in Cloudinary dashboard:
# Settings → Upload → Upload presets → Add upload preset → Signing mode: Unsigned

# Optional — disable MongoDB and use local JSON files (dev/demo only)
# SKIP_DB=1
